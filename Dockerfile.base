FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04 AS base
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/root/.cache/huggingface
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_MODELS=/root/.ollama/models

RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirrors.ovh.net/ubuntu/|g' /etc/apt/sources.list && \
    sed -i 's|http://security.ubuntu.com/ubuntu/|http://mirrors.ovh.net/ubuntu/|g' /etc/apt/sources.list && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends software-properties-common && \
    add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update -y && \
    apt-get install -y --no-install-recommends \
    python3.10 python3.10-venv python3.10-dev python3-pip \
    ffmpeg libsndfile1 curl zstd && \
    rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

RUN curl -fsSL https://ollama.com/install.sh | sh
WORKDIR /app
COPY requirements.txt .

RUN pip install --no-cache-dir packaging setuptools wheel

RUN pip install --no-cache-dir torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu121

RUN pip install --no-cache-dir -r requirements.txt

RUN pip install --no-cache-dir stable-audio-tools
RUN pip install --no-cache-dir einops safetensors

ARG HF_TOKEN
RUN python3 -c "from huggingface_hub import login; login(token='${HF_TOKEN}')" && \
    python3 -c "from diffusers import StableAudioPipeline; StableAudioPipeline.from_pretrained('stabilityai/stable-audio-open-1.0')" && \
    python3 -c "from huggingface_hub import hf_hub_download; [hf_hub_download(repo_id=r, filename=f) for r,f in [('RoyalCities/Foundation-1','Foundation_1.safetensors'),('RoyalCities/Foundation-1','model_config.json'),('innermost47/obsidian-neural-models','audialab-edm-elements.safetensors'),('innermost47/obsidian-neural-models','audialab-edm-elements_model_config.json'),('innermost47/obsidian-neural-models','rc-infinite-pianos.safetensors'),('innermost47/obsidian-neural-models','rc-infinite-pianos_model_config.json'),('innermost47/obsidian-neural-models','rc-vocal-textures.safetensors'),('innermost47/obsidian-neural-models','rc-vocal-textures_model_config.json'),('innermost47/obsidian-neural-models','sao-instrumental.safetensors'),('innermost47/obsidian-neural-models','sao-instrumental_model_config.json'),('innermost47/obsidian-neural-models','stablebeat.safetensors'),('innermost47/obsidian-neural-models','stablebeat_model_config.json'),('innermost47/obsidian-neural-models','gluten-v1.safetensors'),('innermost47/obsidian-neural-models','gluten-v1_model_config.json')]]; print('All models cached.')"

RUN ollama serve & \
    sleep 5 && \
    ollama pull gemma4:e2b && \
    pkill ollama || true